from collections import deque

class Solution:
    def cntOnes(self, grid):
        rows, cols = len(grid), len(grid[0])
        queue = deque()
        enclave_count = 0

        directions = [(-1, 0), (0, -1), (0, 1), (1, 0)]

        # Step 1: Process grid
        for r in range(rows):
            for c in range(cols):
                if grid[r][c] == 1:

                    is_boundary = (
                        r == 0 or r == rows - 1 or
                        c == 0 or c == cols - 1
                    )

                    if is_boundary:
                        # Remove boundary land and add to queue
                        grid[r][c] = 0
                        queue.append((r, c))
                    else:
                        # Count interior land
                        enclave_count += 1

        # Step 2: BFS to remove all land connected to boundary
        while queue:
            x, y = queue.popleft()

            for dx, dy in directions:
                nx, ny = x + dx, y + dy

                if (0 <= nx < rows and 0 <= ny < cols and grid[nx][ny] == 1):
                    grid[nx][ny] = 0
                    queue.append((nx, ny))
                    enclave_count -= 1   # remove from enclave count

        return enclave_count
