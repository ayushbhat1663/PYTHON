def process_dashes(n, s):
    stack = []

    for ch in s:
        if ch == '_':
            if not stack:
                return "-1"
            stack.pop()
        else:
            stack.append(ch)

    result = "".join(stack)
    return result if result else "-1"

def main():
    import sys
    input = sys.stdin.read
    data = input().strip().split()

    n = int(data[0])
    s = data[1]

    result = process_dashes(n, s)
    print(result)

if __name__ == "__main__":
    main()
