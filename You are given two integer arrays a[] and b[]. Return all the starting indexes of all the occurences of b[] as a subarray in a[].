class Solution:
    def search(self, a, b):
        n = len(a)
        m = len(b)
        res = []
        for i in range(n):
            if a[i]==b[0]:
                j = 0
                k = i
                f = True
                while j<m and k<n:
                    if b[j]==a[k]:
                        j+=1
                        k+=1
                    else:
                        f = False
                        break
                if k==n and j<m:
                    f = False
                if f:
                    res.append(i)
        return res
                        
